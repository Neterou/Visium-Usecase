# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable override files — may contain sensitive values
*.tfvars.json
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Sensitive CLI output
*plan.out
tfplan

# OS
.DS_Store
Thumbs.db
